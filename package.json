{
  "name": "terraf",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:extensions": "node verify-extensions.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:ext": "node tf-diff-explainer/scripts/generate-icons.js && vite build --config tf-diff-explainer/vite.scripts.config.ts && vite build --config tf-diff-explainer/vite.background.config.ts && vite build --config tf-diff-explainer/vite.config.ts",
    "dev:ext": "web-ext run --source-dir tf-diff-explainer/dist --target=chromium",
    "test:ext": "vitest run --config tf-diff-explainer/vitest.config.ts",
    "web-ext:run": "web-ext run --source-dir tf-diff-explainer/dist",
    "build:gfe": "node git-file-explainer/scripts/generate-icons.js && vite build --config git-file-explainer/vite.scripts.config.ts && vite build --config git-file-explainer/vite.background.config.ts && vite build --config git-file-explainer/vite.dashboard.config.ts && vite build --config git-file-explainer/vite.config.ts",
    "test:gfe": "vitest run --config git-file-explainer/vitest.config.ts",
    "dev:gfe": "web-ext run --source-dir git-file-explainer/dist --target=chromium",
    "smoke:gfe:filetypes": "node scripts/gfe-realtime-filetype-smoke.mjs",
    "web-ext:build:gfe": "web-ext build --source-dir git-file-explainer/dist --artifacts-dir git-file-explainer/web-ext-artifacts --overwrite-dest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.4.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "puppeteer-core": "^25.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "web-ext": "^10.3.0"
  }
}
