{
  "name": "tf-diff-explainer",
  "version": "0.1.0",
  "description": "Chrome extension that explains Terraform diffs on GitHub PRs and GitLab MRs",
  "scripts": {
    "dev": "web-ext run --source-dir=. --target=chromium",
    "lint": "eslint 'src/**/*.js'",
    "lint:fix": "eslint 'src/**/*.js' --fix",
    "format": "prettier --write 'src/**/*.{js,css,html}'",
    "format:check": "prettier --check 'src/**/*.{js,css,html}'",
    "test": "node tests/pageDetector.test.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "web-ext": "^8.2.0"
  }
}
