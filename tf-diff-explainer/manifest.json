{
  "manifest_version": 3,
  "name": "TF Diff Explainer",
  "version": "0.1.0",
  "description": "Explains Terraform diffs on GitHub PRs and GitLab MRs with risk analysis and AI summaries",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://github.com/*",
    "https://gitlab.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/pull/*",
        "https://gitlab.com/*/merge_requests/*"
      ],
      "js": [
        "src/utils/storage.js",
        "src/content/pageDetector.js",
        "src/content/sidebar/index.js",
        "src/content/index.js"
      ],
      "css": ["src/content/sidebar/sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
