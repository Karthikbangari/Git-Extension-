{
  "env": {
    "browser": true,
    "es2022": true,
    "webextensions": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "error",
    "no-undef": "error"
  },
  "globals": {
    "TFEStorage": "readonly",
    "TFEPageDetector": "readonly",
    "TFESidebar": "readonly"
  }
}
